#!/usr/bin/env ruby

require 'bundler/setup'

require_relative '../lib/ncbo_cron'
config_exists = File.exist?(File.expand_path('../../config/config.rb', __FILE__))
abort("Please create a config/config.rb file using the config/config.rb.sample as a template") unless config_exists
require_relative '../config/config'

def print_alias_resolution(label, solr_url, alias_name)
  connector = SOLR::SolrConnector.new(solr_url, alias_name)
  resolved_collections = connector.resolve_alias(alias_name)
  resolved_value = resolved_collections.empty? ? '(alias not defined)' : resolved_collections.join(', ')

  puts "#{label}: #{alias_name} -> #{resolved_value}"
end

term_alias = Goo.search_collection_target(:term_search_active).to_s
property_alias = Goo.search_collection_target(:property_search_active).to_s

puts "Term search Solr: #{LinkedData.settings.search_server_url}"
print_alias_resolution('Term search alias', LinkedData.settings.search_server_url, term_alias)

puts "Property search Solr: #{LinkedData.settings.property_search_server_url}"
print_alias_resolution('Property search alias', LinkedData.settings.property_search_server_url, property_alias)
